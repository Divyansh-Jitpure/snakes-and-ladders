generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  displayName  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  wonMatches   Match[]       @relation("MatchWinner")
  matchPlayers MatchPlayer[]
  moves        Move[]
}

model Match {
  id          String        @id @default(cuid())
  roomCode    String
  winnerId    String?
  winner      User?         @relation("MatchWinner", fields: [winnerId], references: [id])
  status      MatchStatus   @default(IN_PROGRESS)
  createdAt   DateTime      @default(now())
  finishedAt  DateTime?
  players     MatchPlayer[]
  moves       Move[]

  @@index([roomCode, createdAt])
}

model MatchPlayer {
  id        String   @id @default(cuid())
  matchId   String
  userId    String
  turnOrder Int
  joinedAt  DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
}

model Move {
  id            String   @id @default(cuid())
  matchId       String
  userId        String
  diceRoll      Int
  startPosition Int
  endPosition   Int
  createdAt     DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
}

model GameHistory {
  id         String     @id @default(cuid())
  roomCode   String
  winnerName String
  playerNames Json
  createdAt  DateTime   @default(now())
  moves      GameMove[]

  @@index([createdAt])
  @@index([winnerName])
}

model GameMove {
  id            String       @id @default(cuid())
  historyId     String
  playerName    String
  diceRoll      Int
  startPosition Int
  rawPosition   Int
  endPosition   Int
  jumpType      MoveJumpType?
  createdAt     DateTime     @default(now())

  history GameHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)

  @@index([historyId, createdAt])
}

enum MatchStatus {
  IN_PROGRESS
  FINISHED
}

enum MoveJumpType {
  SNAKE
  LADDER
}
