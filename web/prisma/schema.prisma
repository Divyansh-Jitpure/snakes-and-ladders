generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  name           String?
  email          String?       @unique
  emailVerified  DateTime?
  image          String?
  displayName    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  wonMatches     Match[]       @relation("MatchWinner")
  matchPlayers   MatchPlayer[]
  moves          Move[]
  gameHistories  GameHistory[]
  accounts       Account[]
  sessions       Session[]
}

model Match {
  id          String        @id @default(cuid())
  roomCode    String
  winnerId    String?
  winner      User?         @relation("MatchWinner", fields: [winnerId], references: [id])
  status      MatchStatus   @default(IN_PROGRESS)
  createdAt   DateTime      @default(now())
  finishedAt  DateTime?
  players     MatchPlayer[]
  moves       Move[]

  @@index([roomCode, createdAt])
}

model MatchPlayer {
  id        String   @id @default(cuid())
  matchId   String
  userId    String
  turnOrder Int
  joinedAt  DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
}

model Move {
  id            String   @id @default(cuid())
  matchId       String
  userId        String
  diceRoll      Int
  startPosition Int
  endPosition   Int
  createdAt     DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
}

model GameHistory {
  id              String     @id @default(cuid())
  dedupeKey       String     @unique
  roomCode        String
  winnerName      String
  playerNames     Json
  createdByUserId String?
  createdAt       DateTime   @default(now())
  moves           GameMove[]
  createdBy       User?      @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([winnerName])
  @@index([createdByUserId, createdAt])
}

model GameMove {
  id            String       @id @default(cuid())
  historyId     String
  playerName    String
  diceRoll      Int
  startPosition Int
  rawPosition   Int
  endPosition   Int
  jumpType      MoveJumpType?
  createdAt     DateTime     @default(now())

  history GameHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)

  @@index([historyId, createdAt])
}

enum MatchStatus {
  IN_PROGRESS
  FINISHED
}

enum MoveJumpType {
  SNAKE
  LADDER
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
